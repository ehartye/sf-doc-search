{
  "name": "sf-docs",
  "version": "0.2.0",
  "description": "Retrieve clean Salesforce documentation (dev docs, Help, Trailhead, release notes) without shadow-DOM/render friction.",
  "type": "module",
  "bin": {
    "sf-docs": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "playwright": "^1.48.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
